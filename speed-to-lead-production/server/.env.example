# Speed To Lead — Environment Configuration
# Copy this file to .env and fill in your credentials

# ─── Claude AI ────────────────────────────────────────────────────────────────
CLAUDE_API_KEY=your_claude_api_key_here

# ─── Airtable CRM ─────────────────────────────────────────────────────────────
AIRTABLE_API_KEY=your_airtable_api_key_here
AIRTABLE_BASE_ID=your_airtable_base_id_here

# ─── WhatsApp Business (choose one mode) ─────────────────────────────────────
# Mode: "cloud" = direct WhatsApp Cloud API | "make" = relay via Make.com
WHATSAPP_MODE=make

# If using WhatsApp Cloud API directly:
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id
WHATSAPP_ACCESS_TOKEN=your_whatsapp_access_token

# If using Make.com as relay:
MAKE_OUTBOUND_WEBHOOK=your_make_webhook_url

# ─── Webhook security ─────────────────────────────────────────────────────────
WEBHOOK_VERIFY_TOKEN=speedtolead_secret_2024

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3001
